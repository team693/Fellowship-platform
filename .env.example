# ============================================================================
# Heal Digital Fellowships Platform — Environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or real secrets to git.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase — client-safe (exposed to the browser). These are safe to be public;
# they only work in combination with Row-Level Security policies.
# Find them in: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ----------------------------------------------------------------------------
# Supabase — SERVER ONLY. The service-role key bypasses RLS. It must ONLY ever
# be used in server-side code (route handlers / server actions). It is never
# sent to the browser. Keep it secret.
# Find it in: Supabase Dashboard > Project Settings > API > service_role
# ----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ----------------------------------------------------------------------------
# App configuration
# ----------------------------------------------------------------------------
# The canonical, publicly reachable URL of this deployment. Used to build
# certificate verification links and QR codes, and for auth redirects.
# In local dev use http://localhost:3000. On Vercel set this to your domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Storage bucket names (must match the buckets you create in Supabase Storage).
# ----------------------------------------------------------------------------
# Private bucket that holds opt-in LinkedIn spotlight photos.
NEXT_PUBLIC_SPOTLIGHT_BUCKET=spotlight-photos

# ----------------------------------------------------------------------------
# Access model (launch phase).
# OPEN_ACCESS=true  -> any signed-in user can access every PUBLISHED internship
#                      (auto-enrolled; no seat code or payment required).
# OPEN_ACCESS=false -> access is gated by redeemed seat codes / payment.
# Defaults to true when unset. Set to false once paid access is wired up.
# ----------------------------------------------------------------------------
OPEN_ACCESS=true

# ----------------------------------------------------------------------------
# AI proxy (optional). Lets embedded modules use Claude via a server-side proxy
# (/api/ai) without exposing a key in the browser. Leave unset to disable.
# ----------------------------------------------------------------------------
# Your Anthropic API key (server-only, never exposed to the browser).
ANTHROPIC_API_KEY=
# A current Anthropic model id to use for module AI features.
AI_MODEL=claude-3-5-sonnet-latest
# Optional secret for signing AI proxy tokens; falls back to the service-role
# key if unset. Set a random string in production.
HEAL_AI_TOKEN_SECRET=
